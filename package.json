{
  "scripts": {
    "build": "node build.js",
    "test:rules": "node --test firestore.rules.test.js",
    "test:storage": "node --test storage.rules.test.js",
    "test:rtdb:rules": "node --test database.rules.test.js",
    "test:unit": "npm run sync-shared --prefix functions && node --experimental-test-coverage --test functions/__tests__/*.test.js",
    "test:unit:plain": "npm run sync-shared --prefix functions && node --test functions/__tests__/*.test.js",
    "csp:hash": "node tools/compute-csp-hashes.js",
    "csp:print": "node tools/generate-vercel-csp.js",
    "tailwind:build": "tailwindcss -i shared/tailwind.input.css -o shared/tailwind.css --minify",
    "verify:memory": "node tools/verify-memory.js",
    "verify:memory:coverage": "node tools/verify-memory.js --coverage",
    "verify:memory:all": "node tools/verify-memory.js --all-memory",
    "audit:auth": "node tools/audit-auth-callbacks.js",
    "audit:size": "node tools/audit-file-sizes.js",
    "smoke": "node tools/smoke-test/runner.js",
    "smoke:verify": "node tools/smoke-test/verify.js",
    "lint": "eslint .",
    "install:hooks": "node tools/install-git-hooks.js",
    "postinstall": "node tools/install-git-hooks.js",
    "migrate:tenant-slim": "NODE_PATH=functions/node_modules node tools/migrate-tenant-doc-to-slim.js",
    "migrate:tenant-slim:apply": "NODE_PATH=functions/node_modules node tools/migrate-tenant-doc-to-slim.js --apply",
    "backfill:occupancy-log": "node tools/backfill-occupancy-log.js",
    "backfill:occupancy-log:apply": "node tools/backfill-occupancy-log.js --apply",
    "smoke:transfer-tenant": "NODE_PATH=functions/node_modules node tools/smoke-transfer-tenant.js",
    "smoke:transfer-tenant:apply": "NODE_PATH=functions/node_modules node tools/smoke-transfer-tenant.js --apply",
    "deploy:worktree:prep": "bash tools/worktree-deploy-prep.sh prep",
    "deploy:worktree:cleanup": "bash tools/worktree-deploy-prep.sh cleanup",
    "deploy:worktree:status": "bash tools/worktree-deploy-prep.sh status",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.45.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "firebase": "^11.0.0",
    "glob": "^11.0.0",
    "html-minifier-terser": "^7.2.0",
    "tailwindcss": "^3.4.19"
  }
}
