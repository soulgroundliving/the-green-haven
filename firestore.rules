rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    // accountant1@test.com: read-only access to tax-filing.html data only
    function isAccountant() {
      return isSignedIn() && request.auth.token.accountant == true;
    }
    // Tier 3c SaaS prep: building manager has read access to their building(s).
    // Granted via grantBuildingManager CF or tools/grant-building-manager.js.
    // Write operations still require isAdmin(). `managedBuildings` is a string[]
    // custom claim set on the user's Firebase Auth token.
    //
    // P4.6 hardening 2026-05-23: explicit `is list` type guard. CEL `in`
    // operator on a string does SUBSTRING check, not membership — so if a
    // claim is ever set as a string (e.g. by a faulty tool or external
    // grant) instead of an array, `'rooms' in 'rooms_extra'` would silently
    // return true and grant cross-building manager access. The `is list`
    // check short-circuits to false on any non-array shape. Confirmed safe:
    // both writers (tools/grant-building-manager.js + functions/grantBuildingManager.js)
    // set the claim from arrays only, and functions/_authSoT.js:75 already
    // does Array.isArray() defensively. Adding the rule guard is pure
    // defense-in-depth.
    function isBuildingManager(building) {
      return isSignedIn()
        && request.auth.token.managedBuildings is list
        && building in request.auth.token.managedBuildings;
    }

    // ===== REWARDS / SYSTEM / OWNER INFO — public read (catalog/config/landlord profile) =====
    // Read opened to public so disabling Anonymous auth at Firebase Console doesn't
    // break tenant_app pre-LIFF reads. Content is non-sensitive: rewards is a catalog,
    // system holds emergency contacts + PromptPay (already on the receipt), owner_info
    // is the landlord's contact card that appears in tenant_app anyway. Audit 2026-04-27.
    match /rewards/{rewardId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    // Community Quests catalog (Meaning Layer #1) — public read like rewards (a
    // non-sensitive catalog the tenant checklist reads pre/post-LIFF); admin-only
    // write (admin authors quests directly, mirrors the rewards pattern).
    match /quests/{questId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    // Quest claims — the per-period idempotency fence + immutable audit + admin
    // review queue. CF-only writes (claimQuest / reviewQuestClaim via admin SDK).
    // Admin-read for the review queue; a tenant never reads here — their checklist
    // state is mirrored onto gamification.questsToday (already rule-protected).
    match /questClaims/{claimId} {
      allow read:  if isAdmin();
      allow write: if false;
    }
    // Helper-request lifecycle (Meaning Layer #2) — the neighbor-to-neighbor help
    // board. Building-scoped read: a tenant sees ONLY their own building's
    // requests (PDPA — requester/helper names are visible within the building,
    // never across buildings). Admin reads all (the moderation monitor). CF-only
    // writes: postHelpRequest / acceptHelpRequest / completeHelpRequest /
    // cancelHelpRequest (admin SDK bypasses rules; every transition is a callable).
    match /helpRequests/{requestId} {
      allow read:  if isAdmin()
                || (isSignedIn() && request.auth.token.building != null
                    && resource.data.building == request.auth.token.building);
      allow write: if false;
    }
    // Community requests board (Meaning Layer #3) — neighbour borrow/share board.
    // Same building-scoped read + CF-only-write contract as helpRequests above
    // (PDPA: requester/offerer room labels are visible within the building only;
    // admin reads all for the moderation monitor). Writes via the callables
    // postCommunityRequest / offerCommunityRequest / fulfillCommunityRequest /
    // cancelCommunityRequest (admin SDK bypasses rules; every transition is a callable).
    match /communityRequests/{requestId} {
      allow read:  if isAdmin()
                || (isSignedIn() && request.auth.token.building != null
                    && resource.data.building == request.auth.token.building);
      allow write: if false;
    }
    // Food sharing feed (Meaning Layer #4) — ephemeral leftover-food share board.
    // Same building-scoped read + CF-only-write contract as the boards above (PDPA:
    // sharer/claimer room labels visible within the building only; admin reads all).
    // Writes via the callables shareFood / claimFood / cancelFood; expired docs are
    // swept by cleanupFoodSharesScheduled (admin SDK bypasses rules).
    match /foodShares/{shareId} {
      allow read:  if isAdmin()
                || (isSignedIn() && request.auth.token.building != null
                    && resource.data.building == request.auth.token.building);
      allow write: if false;
    }
    // Pet Social Graph (Meaning Layer #10) — opt-in building-visible pet directory.
    // Same building-scoped read + CF-only-write contract as the boards above: a
    // tenant sees ONLY their own building's public pet profiles (PDPA: pet name +
    // owner room label are visible within the building only, gated by pet_profile_v1
    // consent; admin reads all for the moderation view). Health/vaccine NEVER live
    // here — petProfiles holds only safe display fields copied server-side by
    // upsertPetProfile (admin SDK bypasses rules; opt-out deletes the doc).
    match /petProfiles/{petId} {
      allow read:  if isAdmin()
                || (isSignedIn() && request.auth.token.building != null
                    && resource.data.building == request.auth.token.building);
      allow write: if false;
    }
    // Pet friend edges (Meaning Layer #10) — pet↔pet links. Same building-scoped
    // read + CF-only-write contract; every transition is a callable
    // (requestPetLink / respondPetLink / removePetLink — admin SDK bypasses rules).
    match /petLinks/{linkId} {
      allow read:  if isAdmin()
                || (isSignedIn() && request.auth.token.building != null
                    && resource.data.building == request.auth.token.building);
      allow write: if false;
    }
    // Trade history memory (Meaning Layer #5) — durable record of every completed
    // marketplace trade. PERSONAL, not building-scoped: the owner reads their own
    // trade log (resource.data.ownerUid == auth.uid); admin reads all (the
    // "ประวัติการแลกเปลี่ยน" monitor). CF-only write: marketplaceStatsAggregator
    // writes it (admin SDK) in the same tx as the tradesCompleted counter. No points.
    match /tradeHistory/{tradeId} {
      allow read:  if isAdmin()
                || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow write: if false;
    }
    match /system/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /owner_info/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ===== LEASE NOTIFICATIONS (auto-emitted by remindLeaseExpiry CF) =====
    // Per-tenant lease-expiry notifications at the 60/30/14/expired tier
    // milestones. Powers in-app 🔔 bell + admin dashboard.
    //
    // Doc ID is deterministic: {building}_{room}_{tier}. CF writes via admin
    // SDK (rules bypassed). Tenants read their own + can mark as read; admin
    // reads/writes everything.
    //
    // Tenant update is gated to `status` and `lastReadAt` only — they can't
    // edit the tier, doc body, or anyone else's notifications.
    match /leaseNotifications/{docId} {
      allow read:   if isAdmin()
                 || (isSignedIn()
                     && resource.data.building == request.auth.token.building
                     && resource.data.room == request.auth.token.room);
      allow create: if isAdmin();  // CF uses admin SDK (bypasses rules)
      allow update: if isAdmin()
                 || (isSignedIn()
                     && resource.data.building == request.auth.token.building
                     && resource.data.room == request.auth.token.room
                     && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'lastReadAt']));
      allow delete: if isAdmin();
    }

    // ===== ANNOUNCEMENTS (unified notice/event/banner — C4 merge 2026-05-17) =====
    // Same audience model as broadcastMessages: 'all' = any signed-in user,
    // otherwise must match request.auth.token.building. Discriminator field
    // `type` is 'notice'|'event'|'banner' — client filters by type for surface
    // (bell vs feed vs banner panel). Read tightened from `if true` to
    // signed-in-required so per-building audience filter actually works.
    // C4 S3 (2026-05-27): write tightened to false — publishAnnouncement CF uses
    // admin SDK which bypasses rules. No client SDK should ever write here directly.
    match /announcements/{annId} {
      allow read:  if isAdmin()
                || (isSignedIn() && resource.data.audience == 'all')
                || (isSignedIn() && resource.data.audience == request.auth.token.building);
      allow write: if false;  // CF only (publishAnnouncement / updateAnnouncement / deleteAnnouncement)
    }

    // broadcastMessages collection DECOMMISSIONED C4 S3 (2026-05-27).
    // Legacy docs remain in Firestore until Admin SDK cleanup script runs.
    // No rule block → Firestore default deny applies to all reads + writes.

    // ===== COMMUNITY EVENTS / DOCS / WELLNESS =====
    // communityEvents DECOMMISSIONED C4 S3 (2026-05-27) — migrated to announcements/.
    match /communityDocuments/{id} { allow read: if true; allow write: if isAdmin(); }
    match /wellness_articles/{id}  { allow read: if true; allow write: if isAdmin(); }

    // ===== MARKETPLACE (tenant-to-tenant listings, building-scoped) =====
    // P4.3 hardening 2026-05-23: create rule now enforces ownerUid == auth.uid
    // so a tenant cannot self-set ownerUid to a victim's UID. Prior rule let
    // an attacker create a listing attributed to someone else — the victim
    // then cannot delete it (own-UID match required for delete) and only
    // admin cleanup unstuck the listing. Confirmed via grep:
    // tenant_app.html:6541 already passes ownerUid: window._authUid, so this
    // rule tightening is transparent to legitimate flow.
    match /marketplace/{id} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.ownerUid);
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.ownerUid);
    }

    // ===== MARKETPLACE CHATS (Sprint 1 — Privacy-First Temporary Chat) =====
    // 1:1 chat between marketplace post owner and an interested party.
    // Replaces the line.me/ti/p/{lineUserId} personal-LINE leak in contactSeller().
    //
    // Schema marketplace_chats/{chatId}:
    //   - participants: [ownerUid, interestedUid]  (size==2; both LIFF uids
    //     i.e. 'line:<userId>'; current caller MUST be one of them on create)
    //   - postId, postTitle, postImageUrl, postPrice   — frozen snapshot at
    //     chat-creation time so context survives post mutation
    //   - lastMessage, lastMessageTime, unreadCount{<uid>: N}, createdAt
    //
    // Chat-list subscribe: where 'participants' array-contains <uid>
    //                      order by lastMessageTime desc.
    // Self-destruct: cleanupMarketplaceChat CF on marketplace status → COMPLETED.
    //                Admin SDK bypass — direct client delete is blocked so a
    //                tenant cannot orphan messages for the counterparty.
    //
    // §7-T avoidance: participants array is frozen on update (request == resource);
    // only lastMessage/lastMessageTime/unreadCount may drift after create.
    match /marketplace_chats/{chatId} {
      allow read:   if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
                  && request.resource.data.participants is list
                  && request.resource.data.participants.size() == 2
                  && request.auth.uid in request.resource.data.participants
                  && request.resource.data.keys().hasAll(['participants', 'postId', 'createdAt'])
                  && request.resource.data.postId is string
                  && request.resource.data.postId.size() <= 64;
      // Update: any participant may update; the participants array itself is
      // frozen (can't drop the counterparty mid-conversation). Permitted field
      // writes include: lastMessage, lastMessageTime, unreadCount.{uid},
      // and (S3 PR 2) lastReadAt.{uid} for read-receipt rendering.
      //
      // S3 PR 3: hiddenBy is CF-only (hideMarketplaceChat + notifyMarketplaceChat
      // use the admin SDK to bypass rules). Otherwise a participant could write
      // hiddenBy[other-uid] and hide the chat from the counterparty.
      allow update: if isSignedIn()
                  && request.auth.uid in resource.data.participants
                  && request.resource.data.participants == resource.data.participants
                  && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['hiddenBy']);
      // Delete: admin/CF only. Tenants cannot delete their own chats — that
      // would orphan messages from the counterparty's view. cleanupMarketplaceChat
      // CF is the canonical removal path.
      allow delete: if isAdmin();

      // Messages — only participants of the parent chat can read/write/send.
      // get() on parent chat doc costs +1 read per op; acceptable trade for
      // the cross-participant gate. Same pattern as tenants/.../pets above.
      match /messages/{messageId} {
        allow read:   if isSignedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/marketplace_chats/$(chatId)).data.participants;
        allow create: if isSignedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/marketplace_chats/$(chatId)).data.participants
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 2000
                    // S3 PR 3: replyTo is an optional nested map { messageId,
                    // senderId, textSnippet } stamped at send-time so the
                    // bubble can render a quote card above the message text.
                    && request.resource.data.keys().hasOnly(['senderId', 'text', 'timestamp', 'isRead', 'replyTo']);
        // Update: only the isRead flag (mark-read flow). Sender CANNOT edit
        // their own text — chat history is immutable. Unsend is handled by
        // unsendMarketplaceMessage CF via admin SDK (bypasses rules).
        allow update: if isSignedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/marketplace_chats/$(chatId)).data.participants
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
        // Delete: cleanupMarketplaceChat CF only (admin SDK bypass).
        allow delete: if isAdmin();
      }
    }

    // ===== COMPLAINTS =====
    // Tenant reads = admin OR linkedAuthUid match OR (legacy docs without
    // linkedAuthUid) room+building match the tenant's custom claims set by
    // linkAuthUid CF. This keeps history visible after the schema change.
    // Create requires linkedAuthUid stamped to caller — closes the original
    // cross-tenant create leak. Audit 2026-04-27.
    match /complaints/{id} {
      allow read:   if isAdmin()
        || (isSignedIn() && resource.data.linkedAuthUid == request.auth.uid)
        || (isSignedIn()
            && resource.data.room == request.auth.token.room
            && resource.data.building == request.auth.token.building);
      allow create: if isSignedIn()
        && request.resource.data.linkedAuthUid == request.auth.uid
        && request.resource.data.keys().hasAll(['linkedAuthUid', 'description', 'room', 'building'])
        && request.resource.data.keys().hasOnly([
             'linkedAuthUid', 'description', 'room', 'building',
             'category', 'severity', 'location', 'startDate',
             'title', 'desc', 'id', 'status', 'createdAt'
           ])
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && request.resource.data.room is string
        && request.resource.data.building is string;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== LEASE REQUESTS (tenant submits renew/moveout, admin approves) =====
    // Tenant must be LIFF-linked (has room/building custom claims via liffSignIn)
    // AND payload must match those claims. Admin can always create (ops/migration).
    // Anonymous fallback removed 2026-04-28: liffSignIn is the canonical sign-in,
    // so any "anonymous create" path was an attacker submitting fake requests
    // for arbitrary rooms (the legitimate frontend gates submitLeaseRequest on
    // _taRoom/_taBuilding which are only set after liffSignIn completes).
    match /leaseRequests/{id} {
      allow read:   if isAdmin();
      allow create: if isAdmin()
        || (isSignedIn()
            && request.resource.data.room == request.auth.token.room
            && request.resource.data.building == request.auth.token.building);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== VERIFIED SLIPS (CF-only writes via Admin SDK; admin reads) =====
    // Admin manual writes/deletes go through the recordManualPayment / clearRoomPaymentSlips
    // callables (Admin SDK bypasses rules) so a live admin browser token can no longer forge,
    // poison, or delete the SlipOK dedup-fence docs directly. See tasks/todo-verifiedslips-cf-only.md.
    match /verifiedSlips/{id} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== TAX SUMMARY (CF writes via admin SDK) =====
    // Accountant (tax-filing.html) also needs read; write is CF-only.
    match /taxSummary/{yearDoc} {
      allow read:  if isAdmin() || isAccountant();
      allow write: if false; // CF-only via admin SDK
    }

    // ===== HISTORICAL REVENUE (Excel-imported pre-launch summaries) =====
    // Accountant reads for tax-filing; only admin can write.
    match /historicalRevenue/{yearDoc} {
      allow read:  if isAdmin() || isAccountant();
      allow write: if isAdmin();
    }

    // ===== MONTHLY EXPENSES (admin write, accountant read for tax-filing) =====
    match /expenses/{building}/{monthKey}/{expId} {
      allow read:  if isAdmin() || isAccountant();
      allow write: if isAdmin();
    }

    // ===== RATE LIMITS (CF only) =====
    match /rateLimits/{key} {
      allow read, write: if false;
    }
    match /phoneOtpRateLimit/{key} {
      allow read, write: if false;
    }

    // ===== LINE RETRY QUEUE (CF writes via admin SDK; admin reads for health board) =====
    match /lineRetryQueue/{key} {
      allow read:  if isAdmin();
      allow write: if false; // CF-only
    }

    // ===== AUTH EVENTS (failed-login audit log — 4B) =====
    // Anyone can create (login hasn't succeeded yet, so auth uid unavailable).
    // Schema-constrained to 4 known fields with size caps to prevent abuse.
    match /auth_events/{eventId} {
      allow create: if request.resource.data.keys().hasOnly(['maskedEmail', 'ua', 'errorCode', 'ts'])
                    && request.resource.data.maskedEmail is string
                    && request.resource.data.maskedEmail.size() <= 100
                    && request.resource.data.ua is string
                    && request.resource.data.ua.size() <= 200
                    && request.resource.data.errorCode is string
                    && request.resource.data.errorCode.size() <= 64;
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // ===== BUILDINGS COLLECTION =====
    // P4.4 hardening 2026-05-23:
    //   - Top-level buildings/{id} stays readable to any signed-in user.
    //     Required for booking.html anonymous-prospect PromptPay read AND
    //     tenant_app payment-config subscribe (own-building only on the
    //     tenant side, but the rule is collection-wide because anon
    //     prospects pre-LIFF don't have a `token.building` claim).
    //     Tenant-visible top-level fields: displayName, promptPayId,
    //     companyName, ownerName, internet subdoc.
    //   - Sensitive admin fields (ownerEmail, contact, address) MOVED to
    //     `buildings/{id}/private/admin` subcollection — admin-read-only.
    //     Prior global readability leaked landlord email/phone/property
    //     address to every signed-in user incl. booking prospects.
    //     BuildingRegistry.update/create now split writes accordingly.
    //     Migration via tools/migrate-buildings-private.js (one-shot, gated).
    //
    // P4.4b defense-in-depth 2026-05-23 (added after live REST verification):
    //   - Top-level writes are split into create/update/delete because the
    //     prior catch-all `allow write: if isAdmin()` did not stop ANYTHING
    //     written into top-level address/contact/ownerEmail by an admin who
    //     forgot to use BuildingRegistry (or by a future code path that
    //     bypasses it). The new guard rejects any write that ADDS or CHANGES
    //     those three fields at top-level — they MUST go to private/admin.
    //     Removal (FieldValue.delete) is still allowed so the cleanup script
    //     and BuildingRegistry future migrations work.
    match /buildings/{buildingId} {
      allow read:   if isSignedIn();

      // Top-level write is admin-only AND must not touch the PII allowlist.
      // create: PII keys cannot appear in the new doc at all.
      // update: PII keys cannot be added or changed (removal IS allowed —
      //         lets cleanup migrations FieldValue.delete them).
      // delete: unrestricted for admins.
      allow create: if isAdmin()
                    && !request.resource.data.keys().hasAny(['address', 'contact', 'ownerEmail']);
      allow update: if isAdmin()
                    && !request.resource.data.diff(resource.data).addedKeys().hasAny(['address', 'contact', 'ownerEmail'])
                    && !request.resource.data.diff(resource.data).changedKeys().hasAny(['address', 'contact', 'ownerEmail']);
      allow delete: if isAdmin();

      // Admin-only contact info — landlord email, phone, building address.
      // Building managers do NOT read this — kept owner-only. If a manager
      // needs it, escalate to global admin.
      match /private/{docId} {
        allow read:  if isAdmin();
        allow write: if isAdmin();
      }

      match /rooms/{roomId} {
        allow read:  if isSignedIn();
        allow write: if isAdmin();

        // CF-only writes (admin SDK bypasses rules); admin reads for dashboard.
        // Frontend (tenant_app + dashboard) does not read or write these directly,
        // so tightening to admin-only here closes a cross-room leak without
        // breaking any caller. Audit 2026-04-27.
        match /maintenanceHistory/{docId} {
          allow read:  if isAdmin();
          allow write: if isAdmin();
        }
        match /complaintHistory/{docId} {
          allow read:  if isAdmin();
          allow write: if isAdmin();
        }
        match /roomConditionReports/{docId} {
          allow read:  if isAdmin();
          allow write: if isAdmin();
        }
      }
    }

    // ===== TENANTS COLLECTION (NESTED: tenants/{building}/list/{roomId}) =====
    // Phase 4C-2: read scoped to own room via linkedAuthUid custom field.
    // Admin reads all rooms. Building manager reads all rooms in their building(s).
    // Tenant reads only their own linked room.
    match /tenants/{building}/list/{roomId} {
      allow read: if isAdmin()
               || isBuildingManager(building)
               || (isSignedIn() && resource.data.linkedAuthUid == request.auth.uid)
               // Claim-based self-read (§7-HH/P): a LIFF tenant whose room+building
               // custom claims match THIS path is the legitimate owner — even when
               // linkedAuthUid is empty or has drifted (anon-UID rotation). Mirrors
               // assertTenantAccess's claim-match path that the tenant-gated CFs
               // already trust. READ ONLY — PII updates keep the stricter
               // linkedAuthUid gate below, and gamification stays CF-write-only.
               || (isSignedIn()
                   && request.auth.token.room == roomId
                   && request.auth.token.building == building);
      // Update: admin always; otherwise self-ownership required AND the
      // protected-field block (gamification/rentAmount/building/roomId/
      // tenantId). Without the linkedAuthUid gate (added 2026-05-22 security
      // sprint, NC-2 fix), any signed-in user — including an anonymous
      // booking prospect — could overwrite name/phone/email/nationalId of
      // any tenant's room doc since the affectedKeys block alone leaves
      // every PII field writable.
      // `reputationTier` + `kindnessTier` + `verifiedHelperTier` + `residentRankTier`
      // are server-mirrored from trustScores by the trust sweep CF (Phase 3.2a v1.x
      // reputation + Meaning Layer #6 kindness + #7 verified-helper + #8 resident-rank).
      // All MUST stay in the protected block so a self-owned tenant can't fake their
      // own tier via devtools (§6 tamper-proof; the CF writes via Admin SDK, bypassing rules).
      allow update: if (
          isAdmin()
          || (isSignedIn() && resource.data.linkedAuthUid == request.auth.uid)
        )
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['gamification', 'rentAmount', 'building', 'roomId', 'tenantId', 'reputationTier', 'kindnessTier', 'verifiedHelperTier', 'residentRankTier']);
      allow create, delete: if isAdmin();
      allow write: if isAdmin();

      match /paymentHistory/{monthKey} {
        allow read:  if isAdmin();
        allow write: if isAdmin();
      }
      match /redemptions/{redemptionId} {
        allow read:  if isAdmin();
        allow write: if isAdmin();
      }
      // Pets — tenant writes their own room. Auth gate mirrors the parent
      // tenants/{b}/list/{r} self-access (f494192, §7-HH/§7-P): claim-match
      // (token.room + token.building == this path) is the PRIMARY gate, so a LIFF
      // tenant whose room doc has an empty/drifted linkedAuthUid — anon-UID
      // rotation, or a vacant/re-linked room — can still manage pets, exactly
      // like every other tenant-write path (which all moved to claim-match while
      // pets were the last one left on bare uid-match). The linkedAuthUid get()
      // stays as an additive fallback: only evaluated when claim-match fails, so
      // the happy path costs no extra doc read. Audit 2026-04-27; claim-match
      // added 2026-06-10 (§7-P — fixes pet save failing on rooms with no
      // linkedAuthUid even though the tenant holds valid room+building claims).
      match /pets/{petId} {
        allow read:  if isSignedIn();
        allow write: if isAdmin()
          || (isSignedIn()
              && request.auth.token.room == roomId
              && request.auth.token.building == building)
          || (isSignedIn() &&
              get(/databases/$(database)/documents/tenants/$(building)/list/$(roomId)).data.linkedAuthUid == request.auth.uid);
      }
      // wellnessClaimed — tenant writes only their own room (linkedAuthUid match
      // via parent doc lookup). Same pattern as pets above. Audit 2026-04-27.
      match /wellnessClaimed/{articleId} {
        allow read:   if isAdmin() ||
          (isSignedIn() &&
           get(/databases/$(database)/documents/tenants/$(building)/list/$(roomId)).data.linkedAuthUid == request.auth.uid);
        allow create: if isAdmin() ||
          (isSignedIn() &&
           get(/databases/$(database)/documents/tenants/$(building)/list/$(roomId)).data.linkedAuthUid == request.auth.uid);
        allow update, delete: if isAdmin();
      }
      // wellnessQuizPassed — server-trusted quiz pass marker (Session B).
      // CF-only create — TIGHTER than wellnessClaimed: only claimWellnessQuizPoints
      // CF (admin SDK bypasses rules) can write here. Direct client writes blocked
      // so a tenant can't forge a passed-marker via Firestore client. Tenant reads
      // own room via linkedAuthUid match. Audit 2026-05-23.
      match /wellnessQuizPassed/{markerId} {
        allow read:   if isAdmin() ||
          (isSignedIn() &&
           get(/databases/$(database)/documents/tenants/$(building)/list/$(roomId)).data.linkedAuthUid == request.auth.uid);
        allow create, update, delete: if isAdmin();
      }
      // contractQuizPassed — server-trusted contract-quiz pass marker (Session B).
      // CF-only create — same rationale as wellnessQuizPassed. Singleton per
      // month (markerId = YYYY-MM); claimContractQuizPoints CF is sole writer.
      match /contractQuizPassed/{markerId} {
        allow read:   if isAdmin() ||
          (isSignedIn() &&
           get(/databases/$(database)/documents/tenants/$(building)/list/$(roomId)).data.linkedAuthUid == request.auth.uid);
        allow create, update, delete: if isAdmin();
      }

      // occupancyLog — append-only audit-grade history of every tenant
      // move-in / move-out / transfer / archive on this room. Written by CFs
      // ONLY (transferTenant, archiveTenantOnMoveOut, convertBookingToTenant,
      // future restoreReturningTenant) via Admin SDK which bypasses these
      // rules. Direct client writes are blocked; updates + deletes are blocked
      // for everyone including admin — the log is tamper-proof.
      //
      // Reads: admin (audit), tenant-self (their own entries — supports DSR
      // requests + "where did I live" view in tenant_app). Cross-tenant reads
      // blocked. See functions/_occupancyLog.js for schema spec. Plan B' S1.
      match /occupancyLog/{eventId} {
        allow read:   if isAdmin()
                     || (isSignedIn()
                         && request.auth.token.tenantId != null
                         && resource.data.tenantId == request.auth.token.tenantId);
        allow create, update, delete: if false;
      }
    }

    // ===== TENANTS ARCHIVE (Phase 1 — preserve identity on move-out) =====
    // Snapshot of tenant doc + its subcollections (paymentHistory, redemptions,
    // wellnessClaimed, pets, complaintFreeMonthAwarded) at the moment admin
    // archives the room. CF-only writes via admin SDK (archiveTenantOnMoveOut)
    // — direct client write blocked because archive must be atomic with the
    // accompanying list-doc blank + subcollection move.
    //
    // Read = admin only (Phase 1). Phase 2 will open scoped read for the
    // returning tenant once the people/{tenantId} model lands.
    match /tenants/{building}/archive/{contractId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();

      // Recursive wildcard so subcollection copies (paymentHistory/{ym},
      // redemptions/{id}, wellnessClaimed/{aid}, pets/{pid}, etc.) inherit
      // the same admin-only access without re-declaring each path.
      match /{subPath=**} {
        allow read:  if isAdmin();
        allow write: if isAdmin();
      }
    }

    // ===== PEOPLE COLLECTION (person-centric identity — Phase 2) =====
    // Holds identity + gamification for ex-tenants who transitioned to community
    // member (role='player'). Owner reads own doc via linkedAuthUid match; admin
    // reads/writes all. CF writes via admin SDK (transitionToPlayer, convertBookingToTenant).
    match /people/{tenantId} {
      // Read: admin always; tenant who owns the doc via UID-match (legacy); OR
      // via tenantId claim minted by liffSignIn (claims-stable, no UID-drift — §7-P).
      // The tenantId claim was added to liffSignIn on 2026-05-17 so that
      // people/{tenantId}.linkedAuthUid drift no longer blocks personal-info reads.
      allow read:  if isAdmin()
        || (isSignedIn() && resource.data.linkedAuthUid == request.auth.uid)
        || (isSignedIn() && request.auth.token.tenantId == tenantId
                         && request.auth.token.tenantId != '');
      allow write: if isAdmin();

      // wellnessClaimed — player reads/creates their own subcollection.
      // Matches the same pattern as tenants/{b}/list/{r}/wellnessClaimed above.
      // tok.tenantId is set by liffSignIn when role='player'.
      match /wellnessClaimed/{articleId} {
        allow read, create: if isAdmin()
          || (isSignedIn()
              && request.auth.token.role == 'player'
              && request.auth.token.tenantId == tenantId);
        allow update, delete: if isAdmin();
      }
      // wellnessQuizPassed (player branch) — server-trusted quiz pass marker.
      // CF-only create. Players read own marker via tenantId claim match. Session B.
      match /wellnessQuizPassed/{markerId} {
        allow read: if isAdmin()
          || (isSignedIn()
              && request.auth.token.role == 'player'
              && request.auth.token.tenantId == tenantId);
        allow create, update, delete: if isAdmin();
      }

      // redemptions — written by redeemReward CF (admin SDK).
      // Player reads own history; admin reads all.
      match /redemptions/{redemptionId} {
        allow read:  if isAdmin()
          || (isSignedIn()
              && request.auth.token.role == 'player'
              && request.auth.token.tenantId == tenantId);
        allow write: if isAdmin();
      }
    }

    // ===== PETS — collectionGroup query support (admin only) =====
    // Admin's pet-approval page calls collectionGroup('pets') to aggregate
    // pets across every tenant doc. The nested rule above only matches the
    // specific path tenants/{b}/list/{r}/pets/{petId}, not collectionGroup
    // queries — without this wildcard rule the query fails with
    // "Missing or insufficient permissions". Tenants never run this query.
    match /{path=**}/pets/{petId} {
      allow read: if isAdmin();
    }

    // ===== WELLNESS CLAIMED — collectionGroup query support (admin only) =====
    // Dashboard insights (Wellness Engagement Matrix) calls
    // collectionGroup('wellnessClaimed') to aggregate read counts per article
    // across every tenant doc. Same pattern as pets above — the nested rule
    // (lines 193-201) only matches the specific path, not collectionGroup
    // queries. Tenants never run this query (admin dashboard only).
    match /{path=**}/wellnessClaimed/{articleId} {
      allow read: if isAdmin();
    }

    // ===== QUIZ PASSED — collectionGroup query support (admin only) =====
    // Dashboard insights "Quiz Engagement" card calls collectionGroup on both
    // markers to aggregate pass rates. Nested rules above only match specific
    // paths; collectionGroup needs its own wildcard. Tenants never run this query.
    match /{path=**}/wellnessQuizPassed/{markerId} {
      allow read: if isAdmin();
    }
    match /{path=**}/contractQuizPassed/{markerId} {
      allow read: if isAdmin();
    }

    // ===== OCCUPANCY LOG — collectionGroup query support (Plan B' S1) =====
    // The nested rule (line ~277) only matches the specific room path
    // tenants/{b}/list/{r}/occupancyLog/{event}, NOT collectionGroup queries.
    // Two use cases for collectionGroup:
    //   (1) admin viewing a tenant's full timeline across rooms
    //   (2) tenant_app showing "ฉันเคยอยู่ห้องไหนบ้าง" (DSR-grade)
    // Tenant-self path requires the doc's tenantId to equal the caller's
    // claim — same gate as the nested rule. Writes blocked everywhere.
    match /{path=**}/occupancyLog/{eventId} {
      allow read: if isAdmin()
               || (isSignedIn()
                   && request.auth.token.tenantId != null
                   && resource.data.tenantId == request.auth.token.tenantId);
      allow write: if false;
    }

    // ===== METER DATA =====
    match /meter_data/{docId} {
      allow read:  if isAdmin()
               || isBuildingManager(resource.data.building)
               || (isSignedIn() && resource.data.roomId == request.auth.token.room && resource.data.building == request.auth.token.building);
      allow write: if isAdmin();
    }

    // ===== LEASES (ARCHIVE) =====
    // Tenant_app reads leases via embedded `tenants/{b}/list/{r}.lease` subobject
    // (Phase 4 SSoT). The historical leases/ collection is admin-only by design —
    // tightening the read closes a cross-room rent/deposit visibility leak.
    // Audit 2026-04-27.
    match /leases/{building}/list/{leaseId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ===== LIFF USER LINKS (LINE → tenant link approval) =====
    // Reads:
    //   - admin always
    //   - LIFF user reading own doc — deterministic UID is 'line:' + userId
    //     per liffSignIn CF. Re-opened to own-doc on 2026-05-21 to enable the
    //     real-time mid-session unlink listener in tenant_app (§7-FF). Own-doc
    //     fields (lineUserId/displayName/room/building/status/requestedAt etc.)
    //     are not sensitive to the user themselves; cross-user reads still blocked.
    // Create (P4.2 hardening 2026-05-23):
    //   - require UID-match: request.auth.uid == 'line:' + userId.
    //     Closes impersonation pre-poisoning of the admin approval queue.
    //     Prior `if isSignedIn()` let any signed-in user (including anon
    //     booking prospect) write arbitrary docs at liffUsers/{anyId} with
    //     arbitrary fields (e.g. status:'approved', displayName containing
    //     '(ผู้ดูแล)').
    //   - field allowlist via hasOnly() locks the schema; lineDisplayName /
    //     linePictureUrl match what tenant_app.html:10141 actually writes.
    //   - size caps bound DoS-via-large-blob.
    //   - status must be 'pending' — caller cannot self-approve.
    // update, delete admin-only (liffSignIn CF / unlinkLiffUser CF / admin UI).
    match /liffUsers/{userId} {
      allow read:   if isAdmin()
                     || (isSignedIn() && request.auth.uid == 'line:' + userId);
      allow create: if isSignedIn()
                     && request.auth.uid == 'line:' + userId
                     && request.resource.data.keys().hasOnly([
                          'lineUserId', 'lineDisplayName', 'linePictureUrl',
                          'room', 'building', 'status', 'requestedAt'
                        ])
                     && request.resource.data.lineUserId is string
                     && request.resource.data.lineUserId.size() <= 64
                     && request.resource.data.lineDisplayName is string
                     && request.resource.data.lineDisplayName.size() <= 100
                     && (!('linePictureUrl' in request.resource.data)
                         || request.resource.data.linePictureUrl.size() <= 512)
                     && request.resource.data.room is string
                     && request.resource.data.room.size() <= 32
                     && request.resource.data.building is string
                     && request.resource.data.building.size() <= 32
                     && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // ===== BOOKINGS (LIFF prospect booking flow) =====
    // CF-only writes — createBookingLock / verifyBookingSlip / expireBookingLocks
    // / convertBookingToTenant all use admin SDK which bypasses rules. Direct
    // client write is denied because lock creation must be atomic (Firestore
    // transaction inside the CF) — without that, two prospects could each create
    // their own lock for the same room.
    //
    // Reads: prospect reads OWN booking only (so the LIFF page can onSnapshot
    // the doc and watch status flip locked → paid → kyc_*). Admin reads all
    // for the dashboard "Booking" sub-tab. Cross-prospect read is blocked —
    // the calendar gets aggregated availability via getRoomAvailability CF
    // (admin SDK aggregates without leaking other prospects' PII).
    match /bookings/{bookingId} {
      allow read:  if isAdmin()
        || (isSignedIn() && resource.data.prospectUid == request.auth.uid)
        // Claim fallback: survives edge-case uid drift (§7-P). lineUserId
        // claim is set by liffBookingSignIn and persisted via setCustomUserClaims.
        || (isSignedIn()
            && request.auth.token.role == 'prospect'
            && resource.data.prospectLineId == request.auth.token.lineUserId);
      allow write: if isAdmin();
    }

    // ===== FACILITY BOOKINGS (Tier 3G) =====
    // Tenant creates a booking only for their own building (token.building match).
    // Tenant reads only their own bookings. Admin reads/writes all
    // (admin bypass on create added 2026-05-21 to match this comment + enable
    // emergency direct writes from Firebase Console; the normal flow is still
    // createFacilityBooking CF which uses admin SDK and bypasses rules anyway).
    // Cancel is handled server-side via cancelFacilityBooking CF.
    match /facilityBookings/{bookingId} {
      // Read paths (any one is sufficient):
      //   (a) admin
      //   (b) tenantUid == auth.uid — works when LIFF session UID matches
      //       the snapshot taken at create time
      //   (c) tenantBuilding + tenantRoom match the caller's custom claims —
      //       survives anon-UID drift (fresh LIFF session mints a new
      //       anonymous UID; claims still point to the same room). Mirrors
      //       checklistInstances pattern at L494-497. Closes §7-P at this
      //       surface — without (c), tenant booking is permanently invisible
      //       after the first LIFF re-open that mints a new anon UID.
      allow read:  if isAdmin()
                || (isSignedIn() && resource.data.tenantUid == request.auth.uid)
                || (isSignedIn()
                    && resource.data.tenantBuilding == request.auth.token.building
                    && resource.data.tenantRoom == request.auth.token.room);
      allow create: if isAdmin()
                 || (isSignedIn()
                    && request.auth.token.building != null
                    && request.resource.data.tenantBuilding == request.auth.token.building
                    && request.resource.data.tenantUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ===== FACILITY CONFIG (Tier 3G) =====
    // Admin configures slots + timeSlots per building+facilityType.
    // Signed-in tenants read to render the slot grid.
    // Doc IDs use the pattern {building}_{facilityType} (e.g. rooms_parking).
    match /facilityConfig/{configId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ===== CHECKLIST TEMPLATES (Tier 3I) =====
    // Admin creates/edits templates per building. Signed-in users read.
    // Doc IDs: {building} (one template per building, overwritten on save).
    match /checklistTemplates/{building} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ===== CHECKLIST INSTANCES (Tier 3I) =====
    // Instances are created by admin CF (createChecklistInstance).
    // Tenant fills in and submits via submitChecklist CF.
    // Admin co-signs via adminSignChecklist CF.
    // All direct client writes are forbidden — CF-only.
    //
    // Tenant read paths (either is sufficient):
    //   (a) tenantUid == auth.uid — works when the user's authUid matches the
    //       linkedAuthUid snapshot at the time the instance was created.
    //   (b) room+building claims match the doc — works after anon-UID drift
    //       (each fresh LIFF session mints a new anonymous UID, but custom
    //       claims still point to the same room). Without (b) a tenant whose
    //       authUid changed since instance creation sees "ยังไม่มี checklist".
    match /checklistInstances/{instanceId} {
      allow read:  if isAdmin()
                || (isSignedIn() && resource.data.tenantUid == request.auth.uid)
                || (isSignedIn()
                    && resource.data.building == request.auth.token.building
                    && resource.data.roomId   == request.auth.token.room);
      allow write: if isAdmin();
    }

    // ===== CONSENTS LEDGER (PDPA evidence) =====
    // consents/{tenantId}_{purpose} — server-side proof that a tenant accepted
    // a privacy notice before personal data was processed. Written by the
    // recordChecklistConsent CF; never client-writable.
    // Tenants can READ their own row (so the LIFF page can avoid re-prompting
    // after a device wipe); admin can read all for audit.
    match /consents/{docId} {
      allow read: if isAdmin()
                || (isSignedIn() && resource.data.authUid == request.auth.uid)
                || (isSignedIn() && resource.data.tenantId == request.auth.token.tenantId);
      allow write: if false;
    }

    // ===== DATA-DELETION AUDIT (PDPA §32) =====
    // dataDeletionLog/{tenantId}_{iso} — immutable audit trail for every
    // erasure request. Written by requestDataDeletion CF (Admin SDK bypass).
    // Tenants read their own row keyed by tenantId claim (NOT auth.uid —
    // survives UID drift per anti-pattern P). Admin reads all for audit.
    match /dataDeletionLog/{docId} {
      allow read: if isAdmin()
                || (isSignedIn() && resource.data.tenantId == request.auth.token.tenantId);
      allow write: if false;
    }

    // ===== POINTS LEDGER (Core Readiness Phase 0) =====
    // pointsLedger/{idempotencyKey} — append-only event log of every gamification
    // point movement (earn/redeem). Written server-side ONLY by the points CFs
    // (claimDailyLoginPoints / claimWellnessQuizPoints / claimContractQuizPoints /
    // complaintAndGamification / verifySlip / redeemReward) in the SAME tx/batch as
    // the gamification.points mutation, so the running total and the event history
    // can never drift. Admin-read for engagement analytics + the future Trust
    // System; tenant self-view is a later feature (add a claim-traced read clause
    // then, not now). NEVER client-writable.
    match /pointsLedger/{entryId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== MAINTENANCE ARCHIVE (Phase 3.1 — peak-repair-season analytics) =====
    // maintenanceArchive/{building}_{roomId}_{ticketId} — lean, append-only copy of
    // every CLOSED maintenance ticket, written server-side ONLY by
    // archiveMaintenanceScheduled (cleanupOldDocs.js) BEFORE the 30-day RTDB purge
    // deletes the live ticket. Preserves repair history (category, created/completed
    // timestamps) for seasonality analytics. NO base64 photos. Admin-read; the CF
    // writes via Admin SDK (bypasses rules), so client write is NEVER allowed.
    match /maintenanceArchive/{archiveId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== TRUST SCORES (Roadmap Phase 3.2a — Reputation, admin-only v1) =====
    // trustScores/{tenantId} — server-computed, tamper-proof reputation (0–100) +
    // factor breakdown, written ONLY by computeTrustScoresScheduled (daily) and the
    // recomputeTrustScores admin callable via the Admin SDK (bypasses rules). The
    // moat collapses if a tenant can influence their own score (§6), so client write
    // is NEVER allowed. Admin-read for the dashboard card; tenant self-view is a
    // deferred tenant-visible-v1.x feature (add a claim-traced read clause then).
    match /trustScores/{tenantId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== BEHAVIORAL ROLLUP (Behavioral Analytics Phase 1b — dead-feature detector) =====
    // behavioralRollup/{id} (id='adoption') — identity-free adoption aggregate (per-page /
    // per-action counts + distinct-room COUNTS, never room ids) written ONLY by
    // rollupBehaviorEventsScheduled via the Admin SDK. Admin-read for the dashboard card;
    // client write is NEVER allowed (server-computed aggregate).
    match /behavioralRollup/{id} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== ACTION AUDIT (Core Readiness Phase 1.1) =====
    // actionAudit/{autoId} — immutable, server-side record of admin actions
    // (tenant edit, payment verify, meter-import approve, bill paid, …). Replaces
    // the old per-browser, clearable localStorage "audit log" that audit-log-viewer
    // read. Written ONLY by the recordAdminAction callable (admin SDK bypass) or by
    // a CF logging in-tx via _actionAudit. actor/role/ip/time are stamped server-side
    // from the verified context — never client-supplied. Admin-read for the viewer;
    // tenant self-view is not a v1 feature. NEVER client-writable.
    match /actionAudit/{entryId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // counters/{docType}_{building}_{BE} — gapless running document-number
    // sequences: receipt_{building}_{BE} (Roadmap 1.2a) + invoice_{building}_{BE}
    // (Roadmap 1.2). Mutated ONLY inside a server transaction (verifySlip /
    // assignReceiptNumber / notifyTenantOnMeterUpload CF) so the sequence stays
    // gapless and tamper-proof. Admin-read for reconciliation; NEVER client-writable
    // (a client increment would corrupt the gapless invariant).
    match /counters/{counterId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // manualReceipts/{building}_{roomId}_{billId} — the gapless source of truth for
    // a MANUAL (cash) payment's receipt number (Roadmap 1.2a PR 1.2a-2). Written ONLY
    // by the assignReceiptNumber CF, atomically with the counter increment (a slip's
    // number lives on verifiedSlips instead). Admin-read for reconciliation; NEVER
    // client-writable (would corrupt the gapless invariant).
    match /manualReceipts/{receiptId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // invoices/{building}_{roomId}_{period} — the persisted, immutable
    // document-of-record for an ISSUED invoice (ใบแจ้งหนี้), carrying the gapless
    // INV-{building}-{BE}-{NNNNN} number (Roadmap 1.2). Written ONLY inside the
    // notifyTenantOnMeterUpload CF transaction (mint + record + BILL_ISSUED audit,
    // atomic) and later flipped to status:'void' by the voidInvoice CF (Phase 1.3) —
    // never hard-deleted or overwritten. Admin-read for reconciliation; NEVER
    // client-writable (would corrupt the gapless invariant / the issuance record).
    match /invoices/{invoiceId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== DEPOSITS (admin manages; accountant reads for tax reporting) =====
    // Flat collection: deposits/{building}_{roomId} (e.g. deposits/rooms_15)
    // Each doc stores building + roomId fields for client-side filtering.
    // Tenants have no direct access — deposit status surfaced via tenant SSoT.
    match /deposits/{docId} {
      allow read:   if isAdmin() || isAccountant();
      allow write:  if isAdmin();

      // Per-settlement immutable history (evidence per tenancy): when a room
      // turns over, the prior settlement (deductions + evidence Storage paths +
      // refund slip) is archived here so a room's move-out condition survives
      // for comparison against the next tenant. Same access as the parent doc.
      match /history/{settlementId} {
        allow read:   if isAdmin() || isAccountant();
        allow write:  if isAdmin();
      }
    }

    // ===== PRESENCE (Sprint 7 follow-up — in-app activity tracking) =====
    // presence/{lineUserId} = { lastActiveAt: ISO timestamp }
    // Tenant self-writes a heartbeat from tenant_app while document.visibilityState
    // === 'visible'. notifyMarketplaceChat reads this doc and suppresses the
    // LINE OA push when lastActiveAt is within ~90s (recipient is in-app, the
    // in-app toast already covers the notification). Write contract is
    // intentionally restrictive: ONLY the lastActiveAt field, self-only, no
    // other keys. CF-side (admin SDK) bypasses these rules for cleanup.
    match /presence/{userId} {
      allow read:   if isAdmin()
                     || (isSignedIn() && request.auth.uid == 'line:' + userId);
      allow write:  if isSignedIn()
                     && request.auth.uid == 'line:' + userId
                     && request.resource.data.keys().hasOnly(['lastActiveAt'])
                     && request.resource.data.lastActiveAt is timestamp;
    }

    // ===== DEFAULT DENY (catch-all) =====
    // (`roomWifi/*` decommissioned 2026-05-18 — tenants self-install ISP per room;
    //  app provides /api/speed-test instead. See tools/cleanup-roomWifi.js to purge
    //  orphaned docs. Lifecycle doc: lifecycle_room_wifi.md "decommissioned".)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
