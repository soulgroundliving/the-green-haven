rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    // Temporary admin check until custom claims are set up:
    // admin logs in via email/password, tenants via anonymous.
    // Any non-anonymous signed-in user is treated as admin.
    function isAdminOrEmail() {
      return isSignedIn() &&
        (request.auth.token.admin == true ||
         request.auth.token.firebase.sign_in_provider != 'anonymous');
    }

    // ===== REWARDS COLLECTION (admin-managed catalog, all auth users can read) =====
    match /rewards/{rewardId} {
      allow read:  if isSignedIn();
      allow write: if isAdminOrEmail();
    }

    // ===== SYSTEM CONFIG (emergency contacts, app-wide settings) =====
    match /system/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdminOrEmail();
    }

    // ===== ANNOUNCEMENTS (admin-published) =====
    match /announcements/{annId} {
      allow read:  if true;  // public-ish tenant content
      allow write: if isAdminOrEmail();
    }

    // ===== COMMUNITY EVENTS / DOCS / WELLNESS =====
    // Read is public-ish (tenant-facing content, no PII) — avoids auth race on F5.
    // Write still requires admin (email auth via isAdminOrEmail until claims set up).
    match /communityEvents/{id}    { allow read: if true; allow write: if isAdminOrEmail(); }
    match /communityDocs/{id}      { allow read: if true; allow write: if isAdminOrEmail(); }
    match /wellness_articles/{id}  { allow read: if true; allow write: if isAdminOrEmail(); }

    // ===== COMPLAINTS (cross-collection, simpler than per-room subcollection) =====
    match /complaints/{id} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== LEASE REQUESTS (tenant submits renew/moveout, admin approves) =====
    match /leaseRequests/{id} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== VERIFIED SLIPS (CF writes, admin reads) =====
    match /verifiedSlips/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ===== TAX SUMMARY (CF writes via admin SDK, admin dashboard reads) =====
    // Sensitive financial data — locked to authenticated reads (admin only ideally,
    // but custom claims not yet set up; tighten to isAdmin() once admin claim exists).
    match /taxSummary/{yearDoc} {
      allow read:  if isSignedIn();
      allow write: if false; // CF-only via admin SDK
    }

    // ===== HISTORICAL REVENUE (Excel-imported pre-launch annual summaries) =====
    // Phase 2c: persist HISTORICAL_DATA across devices. Admin (email auth) writes
    // via Excel import or migration button; tenants read for charts.
    match /historicalRevenue/{yearDoc} {
      allow read:  if isSignedIn();
      allow write: if isAdminOrEmail();
    }

    // ===== RATE LIMITS (CF only) =====
    match /rateLimits/{key} {
      allow read, write: if false;
    }

    // ===== BUILDINGS COLLECTION =====
    match /buildings/{buildingId} {
      // Anyone signed in can read building config (PromptPay #, company name)
      allow read:  if isSignedIn();
      allow write: if isAdminOrEmail();

      // Per-room subcollection
      match /rooms/{roomId} {
        allow read:  if isSignedIn();
        allow write: if isAdmin();

        match /maintenanceHistory/{docId} {
          allow read, write: if isSignedIn();
        }
        match /complaintHistory/{docId} {
          allow read, write: if isSignedIn();
        }
        match /roomConditionReports/{docId} {
          allow read:  if isSignedIn();
          allow write: if isAdmin();
        }
      }
    }

    // ===== TENANTS COLLECTION (NESTED: tenants/{building}/list/{roomId}) =====
    // Schema verified 2026-04-18: nested by building, doc id = roomId.
    match /tenants/{building}/list/{roomId} {
      // Any authenticated user can read tenant info
      // (Stricter per-room access requires LIFF→Firebase Auth uid mapping; defer until launch+1)
      allow read: if isSignedIn();

      // Tenant can update their own contact fields (phone/email/licensePlate)
      // but cannot touch gamification subobject (CF-only) or lease-critical fields
      allow update: if isSignedIn() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['gamification', 'rentAmount', 'building', 'roomId', 'tenantId']);

      // Admin full access
      allow create, delete: if isAdmin();
      allow write: if isAdmin();

      // Sub: paymentHistory (CF writes via verifySlip)
      match /paymentHistory/{monthKey} {
        allow read:  if isSignedIn();
        allow write: if isAdmin();
      }
      // Sub: redemptions (redeemReward CF writes; tenant can read own)
      match /redemptions/{redemptionId} {
        allow read:  if isSignedIn();
        allow write: if isAdmin();
      }
      // Sub: pets (Sprint B: tenant manages own pet records)
      match /pets/{petId} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // ===== METER DATA =====
    match /meter_data/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ===== LEASES (ARCHIVE) =====
    match /leases/{building}/list/{leaseId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ===== LIFF USER LINKS (LINE → tenant link approval) =====
    match /liffUsers/{userId} {
      allow read:  if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ===== DEFAULT DENY (catch-all) =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
