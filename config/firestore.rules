rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read and write all collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Meta data (tenant lease info) - allow public read for tenant app
    match /meta_data/{roomId} {
      allow read: if true;  // Allow public read for tenant app
      allow write: if request.auth != null;  // Only authenticated users can write
    }

    // Specific rules for meter_data collection
    // Allow public reads for meter readings (used by tenant app)
    // Only authenticated admins can write
    match /meter_data/{document=**} {
      allow read: if true;  // Public read for tenant app
      allow write: if request.auth != null;  // Only authenticated admins
    }

    // Specific rules for opening_balances collection
    match /opening_balances/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Owner info (single document)
    match /owner_info/main {
      allow read, write: if request.auth != null;
    }

    // Tenants by building
    match /tenants/{building}/{tenantId} {
      allow read, write: if request.auth != null;
    }

    // Leases by building
    match /leases/{building}/{leaseId} {
      allow read, write: if request.auth != null;
    }

    // User data (for tenant profile and sync)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }

    // Bills per tenant
    match /bills/{userId}/{billId} {
      allow read, write: if request.auth.uid == userId;
      allow read, write: if request.auth != null && resource.data.building != null;
    }

    // Maintenance tickets
    match /maintenance/{building}/{ticketId} {
      allow read, write: if request.auth != null;
    }

    // Announcements (read-only for tenants, write for admin)
    match /announcements/{building}/{announcementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Payment history
    match /payments/{userId}/{paymentId} {
      allow read, write: if request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Room configuration
    match /rooms/{building}/{roomId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
