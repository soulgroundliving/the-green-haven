{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || auth.token.admin == true)",
        ".write": "auth != null && (auth.uid == $uid || auth.token.admin == true)"
      }
    },

    "bills": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$building": {
        "$room": {
          "$billId": {
            ".validate": "newData.hasChildren(['billId']) || !newData.exists()"
          }
        }
      }
    },

    "payments": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$building": {
        "$room": {
          "$pushId": {
            ".validate": "newData.hasChildren(['amount']) || !newData.exists()"
          }
        }
      }
    },

    "maintenance": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "housekeeping": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "meter_readings": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin == true"
    },

    "tenants": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin == true"
    },

    "system": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin == true"
    },

    "financials": {
      ".read": "auth != null && auth.token.admin == true",
      ".write": "auth != null && auth.token.admin == true"
    },

    "audit_logs": {
      ".read": "auth != null && auth.token.admin == true",
      ".write": "auth != null"
    }
  }
}
