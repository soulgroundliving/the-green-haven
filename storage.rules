rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ===== HELPERS =====
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    // Files capped at 10 MB regardless of role.
    function fitsSizeLimit() {
      return request.resource.size < 10 * 1024 * 1024;
    }
    // Allow common image + PDF mime types only.
    function isImageOrPdf() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }

    // ===== PETS — photo + vaccine book =====
    // Path: pets/{building}/{room}/{petId}/{file=**}
    // Write scoped to the caller's own room/building via custom claims (set by
    // liffSignIn). Admin bypasses for ops/cleanup. Without this scoping any
    // signed-in tenant could overwrite another room's pet photos or fill the
    // bucket with orphan files (quota / data-poisoning risk). Audit 2026-04-28.
    match /pets/{building}/{room}/{petId}/{file=**} {
      allow read: if isSignedIn();
      allow write: if fitsSizeLimit() && isImageOrPdf()
        && (isAdmin()
            || (isSignedIn()
                && request.auth.token.room == room
                && request.auth.token.building == building));
      allow delete: if isAdmin();
    }

    // ===== LEASES — admin uploads tenant docs =====
    // Path: leases/{building}/{roomId}/{leaseId}/{fileName}
    // Read scoped: only admin OR the tenant of that room (via claims). Old
    // rule allowed any signed-in user to read any lease — privacy leak (rent
    // amount, deposit, signatures across all tenants). Audit 2026-04-28.
    match /leases/{building}/{roomId}/{leaseId}/{fileName} {
      allow read:   if isAdmin()
        || (isSignedIn()
            && request.auth.token.room == roomId
            && request.auth.token.building == building);
      allow write:  if isAdmin() && fitsSizeLimit() && isImageOrPdf();
      allow delete: if isAdmin();
    }

    // ===== BOOKING SLIPS — CF-only writes, admin/owner reads =====
    // Path: bookings/{bookingId}/slips/{fileName}
    // Slip image saved by verifyBookingSlip CF (admin SDK bypasses rules).
    // Direct client write blocked: the CF re-validates against SlipOK + atomic
    // verifiedSlips dedup; client write would skip both.
    // Read scoped to admin OR the booking owner (firestore.get cross-check).
    match /bookings/{bookingId}/slips/{fileName} {
      allow read: if isAdmin()
        || (isSignedIn() &&
            firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.prospectUid == request.auth.uid);
      allow write, delete: if false; // CF-only via admin SDK
    }

    // ===== BOOKING KYC DOCS — owner uploads (Phase 5), admin/owner reads =====
    // Path: bookings/{bookingId}/kyc/{fileName}
    // Owner can upload AFTER status=='paid' (gates on the booking doc state
    // via firestore.get — prevents pre-payment KYC scrape attempts).
    // Files capped at 5MB (KYC scans don't need full 10MB allowance).
    match /bookings/{bookingId}/kyc/{fileName} {
      allow read: if isAdmin()
        || (isSignedIn() &&
            firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.prospectUid == request.auth.uid);
      // Status guard uses explicit `||` instead of `status in [...]` for maximum
      // CEL-version compatibility on Storage Rules. The 3 firestore.get() calls
      // each cost ~$0.06/100k and Firestore caches reads within a single rule
      // evaluation, so practical cost is ~1 read per upload.
      allow write: if isAdmin()
        || (isSignedIn()
            && request.resource.size < 5 * 1024 * 1024
            && isImageOrPdf()
            && firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.prospectUid == request.auth.uid
            && (firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.status == 'paid'
                || firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.status == 'kyc_pending'));
      allow delete: if isAdmin();
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
