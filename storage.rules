rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ===== HELPERS =====
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    // Files capped at 10 MB regardless of role.
    function fitsSizeLimit() {
      return request.resource.size < 10 * 1024 * 1024;
    }
    // Allow common image + PDF mime types only.
    function isImageOrPdf() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }

    // SoT fallback — mirrors functions/_authSoT.js assertTenantAccess
    // Paths 1b / 2a. Called via `||` short-circuit AFTER the claim-equality
    // check fails, so the Firestore read costs nothing on the happy path.
    //
    // Survives §7-Z claim-strip (legacy custom tokens minted before
    // liffSignIn's setCustomUserClaims fix can lose room/building claims
    // after Firebase's ~1h ID token auto-refresh) and §7-HH stale LIFF
    // webview UID — as long as the caller is still the registered tenant
    // of `tenants/{building}/list/{roomId}` per Firestore SoT.
    //
    // Cost: +1 firestore.get per SoT-fallback evaluation. Happy path
    // (claim match) hits 0 reads thanks to CEL `||` short-circuit.
    // Returns false if the tenant doc doesn't exist — caller's claim
    // check is then the only path, matching the original behavior.
    function isLinkedTenant(building, roomId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/tenants/$(building)/list/$(roomId))
        && (firestore.get(/databases/(default)/documents/tenants/$(building)/list/$(roomId)).data.linkedAuthUid == request.auth.uid
            || (request.auth.token.tenantId != null
                && request.auth.token.tenantId != ''
                && firestore.get(/databases/(default)/documents/tenants/$(building)/list/$(roomId)).data.tenantId == request.auth.token.tenantId));
    }

    // ===== PETS — photo + vaccine book =====
    // Path: pets/{building}/{room}/{petId}/{file=**}
    // Write + READ scoped to the caller's own room/building via custom claims
    // (set by liffSignIn). Admin bypasses for ops/cleanup. Audit 2026-04-28
    // covered writes; 2026-05-23 audit also tightened READ from `isSignedIn()`
    // to claim-match because (a) the prior rule let a new tenant of room 15
    // read the old tenant's vaccine book PDF if they enumerated petId, and
    // (b) photoURL/vaccineBookURL tokens persist in archived Firestore docs
    // even after archiveTenantOnMoveOut deletes the Storage files.
    //
    // Tenants only render their OWN pets via the room-scoped subscription at
    // tenants/{b}/list/{r}/pets — never need cross-room read. Admin queue
    // uses the Firestore-stored download tokens (photoURL field) not direct
    // Storage paths so admin reading via `isAdmin()` covers operational use.
    match /pets/{building}/{room}/{petId}/{file=**} {
      allow read: if isAdmin()
        || (isSignedIn()
            && request.auth.token.room == room
            && request.auth.token.building == building);
      allow write: if fitsSizeLimit() && isImageOrPdf()
        && (isAdmin()
            || (isSignedIn()
                && request.auth.token.room == room
                && request.auth.token.building == building));
      allow delete: if isAdmin();
    }

    // ===== LEASES — admin uploads tenant docs =====
    // Path: leases/{building}/{roomId}/{leaseId}/{fileName}
    // Read scoped: only admin OR the tenant of that room. Claim-equality
    // is the fast path; isLinkedTenant() is the SoT fallback for §7-Z /
    // §7-HH windows. CF-routed reads (getLeaseDocUrl) bypass Storage rules
    // entirely via Admin SDK, but a tenant might fall back to direct
    // getDownloadURL() in an outage — this keeps that path consistent.
    // Audit 2026-04-28; SoT fallback added 2026-05-22.
    match /leases/{building}/{roomId}/{leaseId}/{fileName} {
      allow read:   if isAdmin()
        || (isSignedIn()
            && (request.auth.token.room == roomId && request.auth.token.building == building
                || isLinkedTenant(building, roomId)));
      allow write:  if isAdmin() && fitsSizeLimit() && isImageOrPdf();
      allow delete: if isAdmin();
    }

    // ===== BOOKING SLIPS — CF-only writes, admin/owner reads =====
    // Path: bookings/{bookingId}/slips/{fileName}
    // Slip image saved by verifyBookingSlip CF (admin SDK bypasses rules).
    // Direct client write blocked: the CF re-validates against SlipOK + atomic
    // verifiedSlips dedup; client write would skip both.
    // Read scoped to admin OR the booking owner (firestore.get cross-check).
    match /bookings/{bookingId}/slips/{fileName} {
      allow read: if isAdmin()
        || (isSignedIn() &&
            firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.prospectUid == request.auth.uid);
      allow write, delete: if false; // CF-only via admin SDK
    }

    // ===== BOOKING KYC DOCS — owner uploads (Phase 5), admin/owner reads =====
    // Path: bookings/{bookingId}/kyc/{fileName}
    // Owner can upload AFTER status=='paid' (gates on the booking doc state
    // via firestore.get — prevents pre-payment KYC scrape attempts).
    // Files capped at 5MB (KYC scans don't need full 10MB allowance).
    match /bookings/{bookingId}/kyc/{fileName} {
      allow read: if isAdmin()
        || (isSignedIn() &&
            firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.prospectUid == request.auth.uid);
      // Status guard uses explicit `||` instead of `status in [...]` for maximum
      // CEL-version compatibility on Storage Rules. The 3 firestore.get() calls
      // each cost ~$0.06/100k and Firestore caches reads within a single rule
      // evaluation, so practical cost is ~1 read per upload.
      allow write: if isAdmin()
        || (isSignedIn()
            && request.resource.size < 5 * 1024 * 1024
            && isImageOrPdf()
            && firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.prospectUid == request.auth.uid
            && (firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.status == 'paid'
                || firestore.get(/databases/(default)/documents/bookings/$(bookingId)).data.status == 'kyc_pending'));
      allow delete: if isAdmin();
    }

    // ===== CHECKLIST PHOTOS + SIGNATURES (Tier 3I) =====
    // Path: checklists/{building}/{roomId}/{instanceId}/{fileName}
    // Tenant uploads photos/signature for their own instance.
    // Admin reads all (for co-sign review). Tenant reads own instance files.
    //
    // Two-layer auth (matches functions/_authSoT.js + getChecklistMediaUrl):
    //  1. Tenant identity gate — claim-equality OR isLinkedTenant() SoT
    //     fallback (§7-Z / §7-HH survival). CF-routed reads (signed URLs)
    //     bypass these rules via Admin SDK, but direct getDownloadURL()
    //     fallbacks hit them.
    //  2. Path-integrity gate — the instance doc at {instanceId} MUST
    //     live at the same building+roomId, so a tenant of room 15
    //     can't forge a path to /checklists/rooms/15/<inst-from-room-16>/.
    //
    // Cost note: firestore.get() results are cached within a single rule
    // evaluation — the checklistInstances doc is read at most once per
    // access. isLinkedTenant() adds 1 read only when the claim check fails.
    // PDPA-sensitive content; SoT fallback added 2026-05-22.
    match /checklists/{building}/{roomId}/{instanceId}/{fileName} {
      allow read: if isAdmin()
        || (isSignedIn()
            && (request.auth.token.room == roomId && request.auth.token.building == building
                || isLinkedTenant(building, roomId))
            && firestore.get(/databases/(default)/documents/checklistInstances/$(instanceId)).data.building == building
            && firestore.get(/databases/(default)/documents/checklistInstances/$(instanceId)).data.roomId == roomId);
      allow write: if fitsSizeLimit() && isImageOrPdf()
        && (isAdmin()
            || (isSignedIn()
                && (request.auth.token.room == roomId && request.auth.token.building == building
                    || isLinkedTenant(building, roomId))
                && firestore.get(/databases/(default)/documents/checklistInstances/$(instanceId)).data.building == building
                && firestore.get(/databases/(default)/documents/checklistInstances/$(instanceId)).data.roomId == roomId));
      allow delete: if isAdmin();
    }

    // Community Documents — admin uploads building rules / emergency procedures
    // / forms etc. Tenants read but cannot write.
    match /communityDocuments/{docId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && fitsSizeLimit() && isImageOrPdf();
      allow delete: if isAdmin();
    }

    // ===== MARKETPLACE — tenant listing images (Spec v1.0 S0.2) =====
    // Path: marketplace/{postId}/{fileName}
    // Read: any signed-in tenant (matches firestore.rules /marketplace read).
    // Write: owner of the marketplace/{postId} Firestore doc (cross-checked via
    //   firestore.get). Doc must exist FIRST — client flow is addDoc → upload.
    // Delete: admin or owner.
    // 10MB cap + image-only — base64 inline was 80KB typical at 400px/q=0.75;
    // Storage gives headroom for higher-res photos in future sprints.
    match /marketplace/{postId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if fitsSizeLimit() && isImageOrPdf()
        && (isAdmin()
            || (isSignedIn()
                && firestore.exists(/databases/(default)/documents/marketplace/$(postId))
                && firestore.get(/databases/(default)/documents/marketplace/$(postId)).data.ownerUid == request.auth.uid));
      allow delete: if isAdmin()
        || (isSignedIn()
            && firestore.exists(/databases/(default)/documents/marketplace/$(postId))
            && firestore.get(/databases/(default)/documents/marketplace/$(postId)).data.ownerUid == request.auth.uid);
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
