{
  "name": "slipok-verification-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for secure SlipOK payment verification",
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "echo \"No tests configured yet\"",
    "sync-shared": "node -e \"require('fs').copyFileSync('../shared/gamification-rules.js', './gamification-rules.js'); console.log('synced gamification-rules.js from shared/')\""
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.4",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^5.0.0",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.1.0"
  }
}
