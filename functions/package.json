{
  "name": "slipok-verification-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for secure SlipOK payment verification",
  "main": "index.js",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "npm run sync-shared && node --test __tests__/*.test.js",
    "sync-shared": "node -e \"require('fs').copyFileSync('../shared/gamification-rules.js', './gamification-rules.js'); console.log('synced gamification-rules.js from shared/')\""
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.1",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.0.0",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.5.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
