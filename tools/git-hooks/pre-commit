#!/bin/bash
# Committed pre-commit hook (canonical source).
# This file is copied into .git/hooks/pre-commit by `tools/install-git-hooks.js`,
# which runs automatically via `npm install` (see package.json `postinstall`).
#
# DO NOT EDIT .git/hooks/pre-commit directly ‚Äî it will be overwritten on next
# `npm install`. Edit THIS file instead, then re-run `npm install` (or `node tools/install-git-hooks.js`).
#
# The hook does these checks:
#   1. Credential leak detection (API keys, secrets in staged files)
#   2. Memory doc drift detection (lifecycle_*.md verifier ‚Äî see verify-via-grep doctrine)
#   2b. CF unit tests (functions/__tests__/*.test.js when functions/ files staged)
#   2c. Scheduled CF change-detection (lifecycle_scheduled_jobs.md must mention any changed pubsub.schedule CF)
#   3. Anti-pattern detection (Firebase compat API, BillStore misuse, auth callbacks, file size, CSP hash drift ¬ß7-II)
#   4. Memory fabricated-path scan (warn-only)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ===== 1. Credential leak detection =====
PATTERNS=(
  'AIzaSy[a-zA-Z0-9_-]{32,}'
  'SLIPOK[a-zA-Z0-9_]{10,}'
  'api[_-]?key\s*[:=]\s*["\047].*["\047]'
  'secret\s*[:=]\s*["\047].*["\047]'
  'password\s*[:=]\s*["\047].*["\047]'
  'private[_-]?key'
  'firebaseConfig\s*[:=]\s*{[^}]*apiKey'
)

echo -e "${YELLOW}üîç Running pre-commit security checks...${NC}"
FOUND_ISSUE=0

for pattern in "${PATTERNS[@]}"; do
  if git diff --cached --name-only | xargs grep -l "$pattern" 2>/dev/null; then
    FILE=$(git diff --cached --name-only | xargs grep -l "$pattern" 2>/dev/null | head -1)
    echo -e "${RED}‚ùå BLOCKED: Potential credentials detected in $FILE${NC}"
    echo -e "${RED}   Pattern: $pattern${NC}"
    FOUND_ISSUE=1
  fi
done

SECRET_FILES=('.env' '.env.local' 'credentials.json' 'firebase-admin-key.json' 'service-account.json')
for secret_file in "${SECRET_FILES[@]}"; do
  if git diff --cached --name-only | grep -E "^$secret_file$|/$secret_file$"; then
    echo -e "${RED}‚ùå BLOCKED: Secret file '$secret_file' is being committed${NC}"
    FOUND_ISSUE=1
  fi
done

if [ $FOUND_ISSUE -eq 1 ]; then
  echo ""
  echo -e "${RED}‚ùå Commit blocked: Remove sensitive data and try again${NC}"
  echo ""
  echo -e "${YELLOW}To bypass (NOT RECOMMENDED): git commit --no-verify${NC}"
  exit 1
fi
echo -e "${GREEN}‚úÖ Security checks passed${NC}"

# ===== 2. Memory doc drift detection (verify-via-grep doctrine) =====
echo -e "${YELLOW}üß™ Verifying memory docs vs code...${NC}"
if ! node tools/verify-memory.js > /tmp/verify-memory.out 2>&1; then
  echo -e "${RED}‚ùå Memory verifier reported drift:${NC}"
  cat /tmp/verify-memory.out
  echo ""
  echo -e "${YELLOW}Fix the doc OR the code, then re-commit. To bypass (NOT RECOMMENDED): git commit --no-verify${NC}"
  exit 1
fi
echo -e "${GREEN}‚úÖ Memory verifier: all green${NC}"

# ===== 2b. CF unit tests (fast, ~200ms) =====
# Run via npm run test:unit (which auto-syncs gamification-rules.js first per PR #92)
# when any functions/ file is staged.
if git diff --cached --name-only | grep -qE "^functions/"; then
  echo -e "${YELLOW}üß™ Running CF unit tests (functions/ changed)...${NC}"
  if ! npm run test:unit > /tmp/unit-tests.out 2>&1; then
    echo -e "${RED}‚ùå CF unit tests failed:${NC}"
    grep -E "‚úñ|fail" /tmp/unit-tests.out | head -20
    echo ""
    echo -e "${YELLOW}Run: npm run test:unit to see full output${NC}"
    exit 1
  fi
  PASS=$(grep "pass" /tmp/unit-tests.out | tail -1 | grep -oE "[0-9]+")
  echo -e "${GREEN}‚úÖ CF unit tests: ${PASS} passed${NC}"
fi

# ===== 2c. Scheduled CF change-detection =====
# If a staged functions/*.js contains pubsub.schedule, it must be mentioned in lifecycle_scheduled_jobs.md.
# Prevents "new CF added but lifecycle doc not updated" drift ‚Äî root cause of 2026-05-26 doc audit findings
# (cleanupChecklistsScheduled.js existed for months without appearing in the doc, count was wrong).
STAGED_FUNCTIONS=$(git diff --cached --name-only | grep -E "^functions/.*\.js$")
if [ -n "$STAGED_FUNCTIONS" ]; then
  SCHEDULED_CF_CHANGED=$(echo "$STAGED_FUNCTIONS" | xargs grep -l "pubsub\.schedule" 2>/dev/null)
  if [ -n "$SCHEDULED_CF_CHANGED" ]; then
    LIFECYCLE_DOC="$HOME/.claude/projects/C--Users-usEr-Downloads-The-green-haven/memory/lifecycle_scheduled_jobs.md"
    if [ -f "$LIFECYCLE_DOC" ]; then
      UNDOCUMENTED=""
      while IFS= read -r cf_path; do
        cf_name=$(basename "$cf_path" .js)
        if ! grep -qi "$cf_name" "$LIFECYCLE_DOC"; then
          UNDOCUMENTED="${UNDOCUMENTED}  ‚Ä¢ ${cf_name}\n"
        fi
      done <<< "$SCHEDULED_CF_CHANGED"
      if [ -n "$UNDOCUMENTED" ]; then
        echo -e "${RED}‚ùå BLOCKED: Scheduled CF(s) missing from lifecycle_scheduled_jobs.md${NC}"
        echo -e "${YELLOW}   Not found in doc:${NC}"
        echo -e "${YELLOW}${UNDOCUMENTED}${NC}"
        echo -e "${YELLOW}   Add an entry (schedule time, region, purpose) to memory/lifecycle_scheduled_jobs.md${NC}"
        exit 1
      fi
      echo -e "${GREEN}‚úÖ Scheduled CF drift check: changed CF(s) found in lifecycle doc${NC}"
    else
      echo -e "${YELLOW}‚öÝÔ∏è  lifecycle_scheduled_jobs.md not found ‚Äî manually verify doc lists all changed CFs:${NC}"
      echo -e "${YELLOW}   $SCHEDULED_CF_CHANGED${NC}"
    fi
  fi
fi

# ===== 3. Anti-pattern detection =====
# Catches the top recurring bugs from CLAUDE.md ¬ß7 anti-patterns before they land in commits.
# Only scans lines ADDED in this commit (grep on diff +lines) to avoid flagging
# pre-existing code that's outside the current change.
echo -e "${YELLOW}üîé Checking for known anti-patterns...${NC}"
ANTIPATTERN_FOUND=0

STAGED_DIFF=$(git diff --cached -- '*.js' '*.html' 2>/dev/null)

# A. Firebase compat API (v11 modular only ‚Äî firebase.{database,auth,storage,functions}() chain calls)
# Wrong:   firebase.database().ref(path).once('value')
#          firebase.functions().httpsCallable('name')
# Correct: window.firebaseGet(window.firebaseRef(window.firebaseDatabase, path))
#          window.firebase.functions.httpsCallable('name')
# `functions` added 2026-05-20 after ¬ß7-B in unlinkLiffUser (commit 03f84fb) slipped through.
if echo "$STAGED_DIFF" | grep -E "^\+" | grep -qvE "^\+\+" && \
   echo "$STAGED_DIFF" | grep -E "^\+[^+]" | grep -qE "firebase\.(database|auth|storage|functions)\(\)|\.ref\(['\"]" ; then
  # narrower check: compat chain call on a firebase service
  if echo "$STAGED_DIFF" | grep -E "^\+[^+]" | grep -qE "firebase\.(database|auth|storage|functions)\(\)\." ; then
    echo -e "${RED}‚ùå BLOCKED: Firebase compat API detected (firebase.{database,auth,storage,functions}().xxx)${NC}"
    echo -e "${YELLOW}   This codebase uses Firebase v11 modular SDK ‚Äî no compat layer exists${NC}"
    echo -e "${YELLOW}   db/auth/storage: use window.firebaseGet / window.firebaseRef / window.firebaseDatabase${NC}"
    echo -e "${YELLOW}   functions:       use window.firebase.functions.httpsCallable('name')${NC}"
    echo -e "${YELLOW}   See CLAUDE.md ¬ß7B for full pattern reference${NC}"
    ANTIPATTERN_FOUND=1
  fi
fi

# B. BillStore.listForYear().filter(b => b.room) ‚Äî RTDB bill docs have no 'room' field
# Wrong:  BillStore.listForYear(bld, y).filter(b => b.room === roomId)
# Correct: BillStore.getByRoom(building, roomId, year)
if echo "$STAGED_DIFF" | grep -E "^\+[^+]" | grep -qE "listForYear.*\.filter\(.*\b(b|bill)\.(room|roomId)\b" ; then
  echo -e "${RED}‚ùå BLOCKED: BillStore.listForYear().filter(b.room) detected${NC}"
  echo -e "${YELLOW}   RTDB bill documents have no 'room' field ‚Äî filter always returns []${NC}"
  echo -e "${YELLOW}   Use: BillStore.getByRoom(building, roomId, year) instead${NC}"
  echo -e "${YELLOW}   See CLAUDE.md ¬ß7D for details${NC}"
  ANTIPATTERN_FOUND=1
fi

# C. addEventListener('liffLinked') for auth-gated data subscriptions in tenant_app
# Wrong:  window.addEventListener('liffLinked', _subscribeBills)
# Correct: _onLiffClaimsReady(_subscribeBills)
STAGED_TENANT=$(git diff --cached -- 'tenant_app.html' 2>/dev/null)
if [ -n "$STAGED_TENANT" ]; then
  if echo "$STAGED_TENANT" | grep -E "^\+[^+]" | grep -qE "addEventListener\(['\"]liffLinked['\"]" ; then
    echo -e "${YELLOW}‚öÝÔ∏è  WARNING: addEventListener('liffLinked') added to tenant_app.html${NC}"
    echo -e "${YELLOW}   Auth-gated reads (Firestore/RTDB needing room/building claims) must use:${NC}"
    echo -e "${YELLOW}     _onLiffClaimsReady(fn)   ‚Äî not addEventListener('liffLinked', fn)${NC}"
    echo -e "${YELLOW}   Admin preview bypasses room checks ‚Üí bug only visible in real LIFF${NC}"
    echo -e "${YELLOW}   See CLAUDE.md ¬ß7A. If intentional, add a comment explaining why.${NC}"
    # Warn only ‚Äî don't block, edge cases exist (non-data event handlers)
  fi
fi

# D. Auto-approving financial actions ‚Äî never allowed (see CLAUDE.md ¬ß7I)
# Catches: programmatic .click() on approve/confirm buttons in admin JS
STAGED_ADMIN=$(git diff --cached -- 'dashboard.html' 'shared/dashboard*.js' 2>/dev/null)
if [ -n "$STAGED_ADMIN" ]; then
  if echo "$STAGED_ADMIN" | grep -E "^\+[^+]" | grep -qE "\.click\(\).*approv|approv.*\.click\(\)|triggerApprove|autoApprove|simulateClick.*confirm" ; then
    echo -e "${RED}‚ùå BLOCKED: Auto-clicking approve/confirm detected in admin code${NC}"
    echo -e "${YELLOW}   Financial/admin approvals must require explicit user interaction${NC}"
    echo -e "${YELLOW}   See CLAUDE.md ¬ß7I ‚Äî production action gate${NC}"
    ANTIPATTERN_FOUND=1
  fi
fi

# E. Inline event handlers (onclick=, onchange=, onload= etc.) in shared/*.js
# Wrong:   <button onclick="doX('${id}')">...</button>          (in template literals)
# Correct: <button data-action="doX" data-room="${id}">...</button>
#          + handler in dashboard-main.js delegation hub
# CSP blocks inline event handlers ‚Äî hashes do NOT apply unless 'unsafe-hashes' is
# present (we deliberately exclude it). Recurring regression: devs add onclick=
# back during new-feature work, ship works fine in dev, breaks silently in prod CSP.
STAGED_SHARED=$(git diff --cached -- 'shared/*.js' 2>/dev/null)
if [ -n "$STAGED_SHARED" ]; then
  if echo "$STAGED_SHARED" | grep -E "^\+[^+]" | grep -qE "on(click|change|input|submit|load|blur|focus|mouseover|mouseout|mousedown|mouseup|keydown|keyup|keypress)\s*=\s*[\"']" ; then
    echo -e "${RED}‚ùå BLOCKED: Inline event handler added in shared/*.js${NC}"
    echo "$STAGED_SHARED" | grep -E "^\+[^+]" | grep -nE "on(click|change|input|submit|load|blur|focus|mouseover|mouseout|mousedown|mouseup|keydown|keyup|keypress)\s*=\s*[\"']" | head -5
    echo -e "${YELLOW}   CSP blocks inline event handlers (hashes do not apply without 'unsafe-hashes')${NC}"
    echo -e "${YELLOW}   Use the centralized delegation hub in shared/dashboard-main.js:${NC}"
    echo -e "${YELLOW}     1. Element:  data-action=\"yourFn\" data-room=\"\${id}\" ...${NC}"
    echo -e "${YELLOW}     2. Handler:  if (a === 'yourFn') { yourFn(el.dataset.room); return; }${NC}"
    echo -e "${YELLOW}   Examples: 'openTenantModal', 'editRoom', 'showPage' already wired${NC}"
    ANTIPATTERN_FOUND=1
  fi
fi

if [ $ANTIPATTERN_FOUND -eq 1 ]; then
  echo ""
  echo -e "${RED}‚ùå Commit blocked: Fix anti-patterns and try again${NC}"
  echo -e "${YELLOW}   Reference: CLAUDE.md ¬ß7 ‚Äî Recurring Anti-Patterns${NC}"
  echo ""
  exit 1
fi
echo -e "${GREEN}‚úÖ Anti-pattern checks passed${NC}"

# E. Auth-callback audit (¬ß7-A / ¬ß7-U / ¬ß7-Z) ‚Äî BLOCKING
# Every raw window.addEventListener('authReady'|'liffLinked', ...) must be
# either (a) inside the _onLiffClaimsReady helper itself, or (b) justified
# with a [audit-skip] comment within 3 lines above. Catches the recurring
# "auth-gated read bypasses _onLiffClaimsReady" bug class repo-wide (not
# just in the staged diff ‚Äî section C above is the diff-level early warning).
if command -v node &> /dev/null && [ -f tools/audit-auth-callbacks.js ]; then
  if ! node tools/audit-auth-callbacks.js > /tmp/audit-auth-callbacks.out 2>&1; then
    cat /tmp/audit-auth-callbacks.out
    echo ""
    echo -e "${RED}‚ùå Commit blocked: unjustified auth-callback listener${NC}"
    echo -e "${YELLOW}   See CLAUDE.md ¬ß7-A / ¬ß7-U / ¬ß7-Z${NC}"
    exit 1
  fi
  echo -e "${GREEN}‚úÖ Auth-callback audit passed${NC}"
fi

# F. File-size gate (3-tier INFO/WARN/BLOCK ‚Äî see tools/file-size-limits.json)
# Blocks only when a tracked file exceeds its hard limit. Soft-limit and
# growth-per-commit are surfaced as warnings (non-blocking). Limits are
# explicit JSON so every bump shows up in git diff with rationale.
if command -v node &> /dev/null && [ -f tools/audit-file-sizes.js ]; then
  node tools/audit-file-sizes.js --quiet > /tmp/audit-size.out 2>&1
  AUDIT_SIZE_EXIT=$?
  if [ $AUDIT_SIZE_EXIT -ne 0 ]; then
    cat /tmp/audit-size.out
    echo ""
    echo -e "${RED}‚ùå Commit blocked: file exceeded hard size limit${NC}"
    echo -e "${YELLOW}   Extract to shared/<feature>.js OR bump 'hard' in tools/file-size-limits.json${NC}"
    exit 1
  fi
  if [ -s /tmp/audit-size.out ]; then
    echo -e "${YELLOW}File-size warnings (non-blocking):${NC}"
    cat /tmp/audit-size.out
  fi
  echo -e "${GREEN}‚úÖ File-size audit passed${NC}"
fi

# G. CSP hash drift detection (¬ß7-II) ‚Äî BLOCKING
# If a tracked HTML file is staged, regen CSP hashes + the vercel.json CSP value.
# Any drift means an inline <style>/<script> block changed without regenerating
# the hashes in tools/csp-hashes.json AND vercel.json ‚Äî would silently break
# production styling/JS on the next CSP enforce render (recurring ¬ß7-II symptom).
#
# Backs up both files, regens, diffs, restores. Block-and-instruct on drift.
TRACKED_CSP_HTMLS='^(index|login|dashboard|tenant_app|tax-filing|audit-log-viewer|payment|booking)\.html$'
if command -v node &> /dev/null \
  && [ -f tools/compute-csp-hashes.js ] \
  && [ -f tools/update-vercel-csp.js ] \
  && git diff --cached --name-only | grep -qE "$TRACKED_CSP_HTMLS"; then
  echo -e "${YELLOW}üîê Tracked HTML edited ‚Äî checking CSP hash drift...${NC}"
  cp tools/csp-hashes.json /tmp/csp-hashes-before.json 2>/dev/null
  cp vercel.json /tmp/vercel-before.json 2>/dev/null
  node tools/compute-csp-hashes.js > /tmp/csp-hash-regen.out 2>&1
  node tools/update-vercel-csp.js > /tmp/csp-vercel-regen.out 2>&1
  HASH_DRIFT=0
  VERCEL_DRIFT=0
  diff -q tools/csp-hashes.json /tmp/csp-hashes-before.json > /dev/null 2>&1 || HASH_DRIFT=1
  diff -q vercel.json /tmp/vercel-before.json > /dev/null 2>&1 || VERCEL_DRIFT=1
  if [ $HASH_DRIFT -eq 1 ] || [ $VERCEL_DRIFT -eq 1 ]; then
    cp /tmp/csp-hashes-before.json tools/csp-hashes.json 2>/dev/null
    cp /tmp/vercel-before.json vercel.json 2>/dev/null
    echo -e "${RED}‚ùå BLOCKED: CSP hashes drifted from your HTML changes${NC}"
    [ $HASH_DRIFT -eq 1 ] && echo -e "${YELLOW}   - tools/csp-hashes.json is stale${NC}"
    [ $VERCEL_DRIFT -eq 1 ] && echo -e "${YELLOW}   - vercel.json CSP header is stale${NC}"
    echo ""
    echo -e "${YELLOW}   You edited an inline <style> or <script> block in a tracked HTML.${NC}"
    echo -e "${YELLOW}   Required fix:${NC}"
    echo -e "${YELLOW}     npm run csp:hash && node tools/update-vercel-csp.js${NC}"
    echo -e "${YELLOW}     git add tools/csp-hashes.json vercel.json${NC}"
    echo -e "${YELLOW}   Then re-commit. See CLAUDE.md ¬ß7-II for the full story.${NC}"
    exit 1
  fi
  echo -e "${GREEN}‚úÖ CSP hashes in sync${NC}"
fi

# ===== 4. Memory fabricated-path scan (warn-only) =====
# Scans handoff/journal/feedback files for backtick-quoted paths that don't
# exist in the codebase ‚Äî catches the "19 errors from one session" class
# before it silently lands in memory. Warn-only: does not block the commit.
if command -v node &> /dev/null && [ -f tools/verify-memory.js ]; then
  if ! node tools/verify-memory.js --all-memory > /tmp/verify-memory-all.out 2>&1; then
    echo -e "${YELLOW}‚öÝÔ∏è  Memory fabricated-path warnings (non-blocking):${NC}"
    grep -E "WARN|‚ùå" /tmp/verify-memory-all.out | head -10
    echo -e "${YELLOW}   Run: npm run verify:memory:all to see full report${NC}"
  fi
fi

exit 0
