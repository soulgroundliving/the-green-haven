# Firebase Configuration
# Copy this file to .env.local and fill in your own values
# DO NOT commit .env.local to git

# Google Firebase API Key (from Firebase Console)
REACT_APP_FIREBASE_API_KEY=AIzaSyCbOKefRd5mXh3ZxlBjhHkonwbWWBtlQmo

# Firebase Auth Domain
REACT_APP_FIREBASE_AUTH_DOMAIN=the-green-haven-d9b20.firebaseapp.com

# Firebase Project ID
REACT_APP_FIREBASE_PROJECT_ID=the-green-haven-d9b20

# Firebase Storage Bucket
