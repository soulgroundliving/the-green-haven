{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/",
      "config/",
      "shared/",
      ".git",
      "README.md",
      "test-*.js",
      "*.md"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/dashboard.html"
      }
    ]
  },
  "database": {
    "rules": "config/database.rules.json"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-functions-debug.log"
      ]
    }
  ]
}
